{
  "python.defaultInterpreterPath": "",
  "cSpell.words": [
    "chromadb",
    "Clusterer",
    "dbscan",
    "fastmcp",
    "IMAS",
    "iterorganization",
    "limitmb",
    "multisegment",
    "ndarray",
    "pagelen",
    "pagenum",
    "procs",
    "pydantic",
    "PYTHONWARNINGS",
    "qparser",
    "streamable",
    "UDUNITS",
    "ureg"
  ],
  "python.terminal.activateEnvironment": true,
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": ["tests"],
  "python.testing.cwd": "${workspaceFolder}",
  "python.testing.autoTestDiscoverOnSaveEnabled": true,
  "python.analysis.typeCheckingMode": "basic",
  "python.envFile": "${workspaceFolder}/.env",
  "chat.mcp.serverSampling": {
    "imas-codex/.vscode/mcp.json: imas": {
      "allowedDuringChat": true
    },
    "imas-codex/.vscode/mcp.json: imas-test": {
      "allowedDuringChat": true
    }
  },
  "editor.formatOnSave": true,
  "[python]": {
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit",
      "source.fixAll.ruff": "explicit"
    }
  },
  "chat.mcp.access": "all",
  "chat.customAgentInSubagent.enabled": true,
  "markdown-pdf.highlightStyle": "solarized-light.css",
  "markdown-pdf.includeDefaultStyles": false,
  "markdown-pdf.mermaidServer": "https://unpkg.com/mermaid/dist/mermaid.min.js",
  "markdown-preview-enhanced.mermaidTheme": "default",
  "markdown-preview-enhanced.enableScriptExecution": true,
  "markdown-preview-enhanced.chromePath": "/usr/bin/google-chrome",
  "chat.mcp.autostart": "never",
  "github.copilot.chat.cli.mcp.enabled": true,
  "chat.useClaudeMdFile": false,
  "git.autofetch": true,
  "git.autofetchPeriod": 120,
  "git.pullBeforeCheckout": true
}
